# ── TradAI — Ejemplo de variables de entorno ─────────────────────────────
# Copia este archivo a `.env` y rellena los valores necesarios:
#   cp .env.example .env
#
# Importante:
# - NO subas `.env` a git (contiene secretos). Este repo ya lo ignora.
# - En Docker Compose, `DATABASE_URL` se sobreescribe automáticamente.

# ── Telegram (obligatorio para usar el bot) ──────────────────────────────
TELEGRAM_BOT_TOKEN=
# Chat donde el bot enviará notificaciones (opcional, pero recomendado)
TELEGRAM_CHAT_ID=
# Lista de user IDs permitidos (separados por comas). Ej: "123,456"
# Si lo dejas vacío, el bot permitirá a cualquiera usar comandos.
TELEGRAM_ALLOWED_USERS=

# ── Base de datos ────────────────────────────────────────────────────────
# Para Docker Compose no hace falta tocar DATABASE_URL (se inyecta en runtime).
# Para ejecución local sin Docker:
# DATABASE_URL=postgresql+asyncpg://tradai:tradai_password@localhost:5432/tradai_db
DATABASE_URL=

# Variables usadas por docker-compose.yml (opcionales)
POSTGRES_USER=tradai
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=tradai_db

# ── OpenAI (opcional; sin esto el bot seguirá funcionando sin IA) ─────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── General ──────────────────────────────────────────────────────────────
TIMEZONE=Europe/Madrid
MONITOR_INTERVAL_MINUTES=10
LOG_LEVEL=INFO
# Límite de concurrencia (threads) para yfinance
YFINANCE_MAX_CONCURRENCY=8

# ── Gestión de riesgos ───────────────────────────────────────────────────
MAX_TICKER_CONCENTRATION=0.05
MAX_SECTOR_CONCENTRATION=0.20
DEFAULT_STOP_LOSS_PCT=0.08
DEFAULT_TAKE_PROFIT_PCT=0.25

# ── eToro (broker principal) ─────────────────────────────────
# Credenciales por defecto (aplican al modo ETORO_MODE)
ETORO_API_KEY=
ETORO_USER_KEY=
ETORO_MODE=demo
# Credenciales separadas por modo (opcional, para dual demo+real)
# Si se configuran, se crean dos clientes independientes.
ETORO_DEMO_API_KEY=
ETORO_DEMO_USER_KEY=
ETORO_REAL_API_KEY=
ETORO_REAL_USER_KEY=
ETORO_AUTO_EXECUTE=true
# Si está en true, BUY/SELL reales solo se confirman si eToro ejecuta.
ETORO_REQUIRE_EXECUTION=true
# Orienta /analizar y /scan a activos operables en eToro.
ETORO_ANALYSIS_ORIENTED=true

# ── Divisa de la cuenta ──────────────────────────────────────
# Moneda base de la cuenta del broker (USD para eToro).
# Los totales de cartera se muestran en esta divisa.
ACCOUNT_CURRENCY=USD

# ── Backtesting autónomo en demo ────────────────────────────
BACKTEST_CONTINUOUS_ENABLED=true
BACKTEST_INTERVAL_MINUTES=60
BACKTEST_PERIODS=6mo,1y
BACKTEST_MAX_TICKERS=20
# Enviar notificación Telegram en cada ciclo (si hay learning logs).
BACKTEST_NOTIFY_EACH_RUN=true
